{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false
  },
  "include": ["hardhat.config.ts", "tasks/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "artifacts", "cache", "dist"]
}
